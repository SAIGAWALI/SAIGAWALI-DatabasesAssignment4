# Database Configuration - Copy to .env and fill with your values
# IMPORTANT: Do NOT commit your actual .env file with real passwords!

# Main Database Credentials (Source DB)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=dms_db

# Sharded Database Credentials
SHARD_DB_USER=root
SHARD_DB_PASSWORD=your_shard_password_here
SHARD_DB_NAME=dms_db

# Shard Server Configuration
SHARD_HOST=10.0.116.184
SHARD_PORT_0=3307
SHARD_PORT_1=3308
SHARD_PORT_2=3309

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your_secret_key_here

# Optional: Logging
LOG_LEVEL=INFO
